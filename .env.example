# --- SMTP-сервер почтового провайдера ---
# Gmail:   SMTP_HOST=smtp.gmail.com   SMTP_PORT=587
# Mail.ru: SMTP_HOST=smtp.mail.ru     SMTP_PORT=465
# Yandex:  SMTP_HOST=smtp.yandex.ru   SMTP_PORT=465
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465

# Полный адрес ящика — он же логин и адрес отправителя
SMTP_USER=твой-ящик@mail.ru

# ПАРОЛЬ ПРИЛОЖЕНИЯ (не основной пароль от почты!):
#   Gmail:   Аккаунт Google → Безопасность → Пароли приложений
#   Mail.ru: Настройки → Безопасность → Пароли для внешних приложений
#   Yandex:  Яндекс ID → Безопасность → Пароли приложений
SMTP_PASSWORD=пароль-приложения

# Имя отправителя, которое увидит покупатель (можно кириллицей)
SMTP_FROM_NAME=Дельфиниум.рф

# Базовый адрес сайта для ссылок в письмах.
# Локально — http://127.0.0.1:8000, на проде — реальный домен сайта.
MAIL_BASE_URL=http://127.0.0.1:8000
